rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Buildings: רק adminUid יכול לקרוא/לכתוב
    match /buildings/{buildingId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.adminUid;

      // Create a new building
      allow create: if request.auth != null
        && request.resource.data.adminUid == request.auth.uid;

      // Sub-collections: tenants, payments, messages, requests, documents, bulletin, activity
      match /{collection}/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/buildings/$(buildingId)).data.adminUid == request.auth.uid;
      }
    }
  }
}
